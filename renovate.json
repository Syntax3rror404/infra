{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "flux": {
    "managerFilePatterns": ["/flux/.+\\.yaml$/"]
  },
  "helm-values": {
    "managerFilePatterns": ["/flux/.+\\.yaml$/"]
  },
  "packageRules": [
    {
      "matchPackageNames": ["ghcr.io/renovatebot/renovate"],
      "automerge": true,
      "automergeType": "branch"
    }
  ]
}
